# Frontend (Vite) — prefix VITE_ to expose to the browser
# The API URL is used by the voice agent for direct server calls (TTS, WebSocket).
# In dev, Vite proxies /api and /socket.io to localhost:4000 automatically,
# so you only need this if you change the server port or deploy.
VITE_API_URL=http://localhost:4000

# Server
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# Dolt database connection
DOLT_HOST=127.0.0.1
DOLT_PORT=3306
DOLT_USER=root
DOLT_PASSWORD=
DOLT_DATABASE=callcenterx

# JWT secret — change this to a long random string in production
JWT_SECRET=change-me-in-production

# ElevenLabs API key for TTS
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here
